# ── Directory roots ────────────────────────────────────────────────────────────
# Repo root — contains data/public.jsonl and data/private.jsonl
ROOT_DIR=/path/to/cse151b/final

# Storage node — large artifacts live here (distillation traces, checkpoints, …)
# Subdirectory layout (auto-created by config.py):
#   $STORAGE_DIR/results/          inference outputs / submission CSVs
#   $STORAGE_DIR/distillation/     teacher reasoning traces for SFT
#   $STORAGE_DIR/checkpoints/      SFT / RL model checkpoints
#   $STORAGE_DIR/cache/            HuggingFace model cache
STORAGE_DIR=/path/to/storage/node
